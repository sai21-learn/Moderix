# Moderix OpenEnv Configuration Example
# Rename this file to .env and fill in your credentials.

# API Endpoint for the LLM (Defaults to OpenAI)
# API_BASE_URL=https://api.openai.com/v1

# The model identifier to use (Defaults to gpt-4o-mini)
# MODEL_NAME=gpt-4o-mini

# Authentication Tokens (Provide at least one)
OPENAI_API_KEY=your_openai_api_key_here
HF_TOKEN=your_hf_token_here

# Optional: Gemini API Fallback
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL_NAME=gemini-2.0-flash

# Optional: Local Image Name (for OpenEnv Docker integration)
LOCAL_IMAGE_NAME=moderix-agent
